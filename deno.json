{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "version": "0.0.1",
  "nodeModulesDir": "auto",
  "jsrDepsInNodeModules": true,
  "preferPackageJson": true,
  "tasks": {
    "dev": "deno run --watch ./src/app.ts",
    "build:compile": " deno compile --bundle --minify --target x86_64-unknown-linux-gnu --output ./dist/web-analyzer ./src/app.ts"
  },
  "imports": {
    "#src/": "./src/"
  },
  "lint": {
    "include": ["./src/*","./rules/*"],
    "rules": { "tags": ["recommended"] }
  },
  "fmt": {
    "lineWidth": 80,
    "include": [
      "./src/*","./rules/*"
    ],
    "semiColons": false,
    "useTabs": false
  },
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": [
      "node",
      "deno.ns",
      "esnext"
    ]
  }
}
