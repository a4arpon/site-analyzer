{
  "disable_ai":false,
  "language_servers": [
    "!typescript-language-server",
    "!oxfmt",
    "!oxlint",
    "deno"
  ],
  "formatter": {
    "language_server": {
      "name": "deno"
    }
  },
  "code_actions_on_format": {
    "source.fixAll.deno": true,
    "source.organizeImports": true
  }
}
